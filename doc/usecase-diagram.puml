@startuml SNS_Final_Ultimate_Fixed

' --- 1. 가독성 및 레이아웃 설정 ---
skinparam Linetype ortho
skinparam nodesep 100
skinparam ranksep 120
skinparam shadowing false
skinparam roundcorner 8
' 일부 환경에서 awesome 스타일 오류 방지를 위해 기본 스타일 사용
skinparam actorStyle human

left to right direction

' --- 2. 행위자 정의 (왼쪽) ---
actor "일반 사용자" as User #White

' --- 3. 시스템 경계 및 유즈케이스 ---
rectangle "SNS 프로젝트 서비스" {
  
  ' 각 패키지에 색상을 직접 지정하여 오류 방지
  package "게시물 관리" #E8F5E9 {
    usecase "게시물 작성 및 관리" as UC_Post
    usecase "미디어 업로드" as UC_Media
    usecase "게시물 인터랙션" as UC_PostInt
    UC_Post ..> UC_Media : <<include>>
  }

  package "실시간 채팅" #E3F2FD {
    usecase "채팅 참여 (1:1/그룹)" as UC_Chat
  }

  package "정산 및 알림" #F3E5F5 {
    usecase "그룹 정산 관리" as UC_Settlement
    usecase "알림 확인 및 관리" as UC_Noti
  }

  package "지도 탐색" #FFFDE7 {
    usecase "지도 기반 탐색" as UC_Map
  }

  package "인증 및 계정" #FCE4EC {
    usecase "프로필 및 관계 관리" as UC_UserMgmt
    usecase "회원가입/로그인" as UC_Auth
  }
}

' --- 4. 외부 시스템 (오른쪽: 수평 배치를 위한 순서 조정) ---
package "외부 연동 시스템" {
  actor "Storage" as FStorage <<System>>
  actor "Realtime DB" as FRealtime <<System>>
  actor "Firestore" as FStore <<System>>
  actor "Google Maps" as GMaps <<System>>
  actor "Firebase Auth" as FAuth <<System>>
}

' --- 5. 사용자 연결 ---
User -- UC_Post
User -- UC_PostInt
User -- UC_Chat
User -- UC_Settlement
User -- UC_Noti
User -- UC_Map
User -- UC_UserMgmt
User -- UC_Auth

' --- 6. 시스템 -> 외부 데이터 흐름 (직각/수평 유지) ---
UC_Media -- FStorage
UC_Chat -- FRealtime

UC_Post -- FStore
UC_PostInt -- FStore
UC_Settlement -- FStore
UC_Noti -- FStore
UC_UserMgmt -- FStore

UC_Map -- GMaps
UC_Auth -- FAuth

@enduml